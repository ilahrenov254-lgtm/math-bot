import os
import re
from telegram import Update
from telegram.ext import Application, CommandHandler, MessageHandler, filters, ContextTypes

TOKEN = "8740014068:AAH_M8MlNz59IhjQ1QCtR3aKvRMA7KPGXqw"

def solve_math(expression):
    try:
        expression = expression.replace('×', '*').replace('÷', '/').replace('^', '**')
        result = eval(expression)
        if isinstance(result, float) and result.is_integer():
            result = int(result)
        return f"✅ {expression} = {result}"
    except:
        return "❌ Не могу решить"

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "🤖 Бот-решатель задач (работает 24/7!)\n\n"
        "📝 Примеры: 2 + 2 × 3\n"
        "📐 Уравнения: x + 5 = 10\n"
        "⚡ Степени: 2 ^ 3\n\n"
        "Просто напиши пример!"
    )

async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = update.message.text.strip()
    if text.startswith('/'):
        return
    
    if '=' in text and 'x' in text.lower():
        try:
            left, right = text.split('=')
            right = int(right.strip())
            if 'x' in left:
                left = left.replace(' ', '')
                if left == 'x':
                    result = right
                elif left.endswith('x'):
                    coeff = int(left.replace('x', ''))
                    result = right / coeff
                else:
                    result = "не могу"
                await update.message.reply_text(f"✅ {text} → x = {result}")
            else:
                await update.message.reply_text("❌ Не могу решить")
        except:
            await update.message.reply_text("❌ Ошибка")
    else:
        result = solve_math(text)
        await update.message.reply_text(result)

def main():
    app = Application.builder().token(TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_text))
    
    print("🤖 Бот запущен на Render!")
    app.run_polling()

if __name__ == "__main__":
    main()
